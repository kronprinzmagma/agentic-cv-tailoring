# cv-tailor — required API keys
# Copy this file to .env and fill in real values.
# .env is gitignored; never commit real keys.

# Anthropic (Claude models: analyst, writer, coach_reviewer, factcheck)
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# OpenAI (hiring_reviewer, translator — Anti-Echo)
OPENAI_API_KEY=sk-REPLACE_ME

# Optional: override the CV author name without editing config.yaml.
# Used to build the recruiter-friendly filename (CV_<Author>-<anchor> ...).
# Spaces are converted to underscores. Example: "Alex Müller" → "CV_Alex_Müller".
# CV_AUTHOR_NAME=
